# ============================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env.production and fill in values
# WARNING: NEVER commit actual .env file to git

# ──── FRONTEND (gorentals-frontend) ────
# Pass to Docker build via:
# docker build --build-arg NEXT_PUBLIC_API_URL=<value> .

NEXT_PUBLIC_API_URL=https://api.production.gorentals.com

# CORS - Production Frontend Domain
CORS_ALLOWED_ORIGINS=https://app.production.gorentals.com

# ──── BACKEND (GORENTALS) ────
# Set these as environment variables in your deployment

# Database (PostgreSQL via Neon or other provider)
DB_URL=postgresql://user:password@host:5432/gorentals
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# JWT - Generate with: openssl rand -hex 32
JWT_SECRET=<generate-32-char-hex-string>

# Payment Gateway - Razorpay
RAZORPAY_KEY_ID=rzp_live_YOUR_PRODUCTION_KEY
RAZORPAY_KEY_SECRET=your_production_secret

# Image Storage - Cloudinary
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Database Provider - Supabase
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Server Configuration
SERVER_PORT=8080
ENVIRONMENT_NAME=production
ENVIRONMENT_MODE=production
