# ─────────────────────────────────────────────────────────────────
# GoRentals Backend — Environment Variables
# Copy this file to .env (local) or paste into your hosting dashboard
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────
# Local:   jdbc:postgresql://localhost:5432/gorentals
# Neon:    jdbc:postgresql://ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DB_URL=jdbc:postgresql://localhost:5432/gorentals
DB_USERNAME=postgres
DB_PASSWORD=your_db_password_here

# ── JWT ──────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
# Minimum 32 characters — app will not start without this
JWT_SECRET=replace_with_at_least_64_char_random_string
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ── Cloudinary ────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── CORS ─────────────────────────────────────────────────────────
# Local dev:
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Production (replace with your real domains, NO trailing slash):
# CORS_ALLOWED_ORIGINS=https://gorentls.vercel.app,https://gorentls.com

# ── JPA / Hibernate ───────────────────────────────────────────────
# Local: update | Production: validate (never create, never drop)
DDL_AUTO=update

# ── Server ────────────────────────────────────────────────────────
PORT=8080
