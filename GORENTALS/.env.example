# ============================================================
#  GoRentals — Environment Variables Template
#  Copy this file, rename to .env, fill in real values.
#  NEVER commit .env to git.
# ============================================================

# ── Database ─────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/rentit
DB_USERNAME=postgres
DB_PASSWORD=your_db_password_here

# ── JWT ──────────────────────────────────────────────────────
# Generate a secure 64-char secret (run once in PowerShell):
#   $bytes = New-Object byte[] 48
#   [System.Security.Cryptography.RandomNumberGenerator]::Fill($bytes)
#   Write-Host "JWT_SECRET=$([System.Convert]::ToBase64String($bytes))"
JWT_SECRET=REPLACE_WITH_GENERATED_SECRET
JWT_EXPIRATION=86400000

# ── Razorpay ────────────────────────────────────────────────
RAZORPAY_KEY=rzp_test_xxx
RAZORPAY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=

# ── App ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
DDL_AUTO=validate

# ── Admin Seed Account ───────────────────────────────────────
APP_ADMIN_EMAIL=admin@gorentals.com
APP_ADMIN_PASSWORD=Admin@GoRentals2025!
APP_ADMIN_NAME=GoRentals Admin

# ── Platform ────────────────────────────────────────────────
COMMISSION_RATE=0.10

# ── CORS ────────────────────────────────────────────────────
CORS_ALLOWED_ORIGIN=http://localhost:3000
