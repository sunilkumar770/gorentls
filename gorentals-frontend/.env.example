# ============================================================
# GoRentals Frontend — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in real values.
#   cp .env.example .env.local
#
# NEVER commit .env.local — it is in .gitignore.
# NEXT_PUBLIC_* vars are exposed to the browser.
# All others are server-only (never exposed to browser).
# ============================================================


# ── Backend API ──────────────────────────────────────────────
# URL of your Spring Boot backend (no trailing slash).
# Local development default: http://localhost:8080/api
# Production (Render/Railway): https://your-backend-domain.com/api
NEXT_PUBLIC_API_URL=http://localhost:8080/api


# ── Razorpay ─────────────────────────────────────────────────
# Your Razorpay KEY ID (public — safe to expose in the browser).
# Test key starts with: rzp_test_
# Live key starts with: rzp_live_
# Get from: https://dashboard.razorpay.com/app/keys
#
# WARNING: If this is missing, the payment modal will open
# with key=undefined and ALL payments will fail silently.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID_HERE


# ── Google Maps (optional) ───────────────────────────────────
# Required only if listing maps/location picker is enabled.
# Get from: https://console.cloud.google.com/apis/credentials
# Leave blank to disable map features.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=


# ── Application URL ──────────────────────────────────────────
# Full URL of the frontend (used for redirects, OG tags, etc.)
# Local: http://localhost:3000
# Production: https://gorentals.in (or your domain)
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ── WebSocket ─────────────────────────────────────────────────
# WebSocket proxy is configured in next.config.ts.
# In development it proxies /ws/** → localhost:8080/ws/**.
# In production, update next.config.ts or set this var:
# NEXT_PUBLIC_WS_URL=wss://your-backend-domain.com/ws
